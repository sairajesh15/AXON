generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  student       Student?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Student {
  id                String              @id @default(cuid())
  userId            String              @unique
  rollNumber        String              @unique
  name              String
  email             String
  course            String
  year              Int
  semester          Int
  department        String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  alertLogs         AlertLog[]
  attendanceRecords AttendanceRecord[]
  attendanceSummary AttendanceSummary[]
  chatSessions      ChatSession[]
  enrollments       Enrollment[]
  user              User                @relation(fields: [userId], references: [id])
  codingActivities  CodingActivity[]
  codingTopics      CodingTopic[]
  dailyCodingLogs   DailyCodingLog[]
  platformUsernames PlatformUsername[]
  studentGoal       StudentGoal?
  studyPlans        StudyPlan[]
}

model Subject {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  department        String
  totalClasses      Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attendanceRecords AttendanceRecord[]
  attendanceSummary AttendanceSummary[]
  enrollments       Enrollment[]
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  studentId String
  subjectId String
  date      DateTime
  status    AttendanceStatus
  markedBy  String
  createdAt DateTime         @default(now())
  student   Student          @relation(fields: [studentId], references: [id])
  subject   Subject          @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, date])
}

model AttendanceSummary {
  id           String   @id @default(cuid())
  studentId    String
  subjectId    String
  totalClasses Int      @default(0)
  attended     Int      @default(0)
  percentage   Float    @default(0)
  riskTier     RiskTier @default(SAFE)
  lastUpdated  DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
}

model AlertLog {
  id        String      @id @default(cuid())
  studentId String
  subjectId String
  alertType AlertType
  sentAt    DateTime    @default(now())
  channel   String      @default("EMAIL")
  status    AlertStatus
  payload   Json?
  student   Student     @relation(fields: [studentId], references: [id])
}

model ChatSession {
  id        String   @id @default(cuid())
  studentId String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])
}

model CodingActivity {
  id             String  @id @default(cuid())
  studentId      String
  platform       String
  problemsSolved Int
  topic          String?
  difficulty     String?
  streakDays     Int     @default(0)
  student        Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("coding_activities")
}

model DailyCodingLog {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  platform  String
  solved    Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, platform])
  @@map("daily_coding_logs")
}

model CodingTopic {
  id        String  @id @default(cuid())
  studentId String
  topicName String
  solved    Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, topicName])
  @@map("coding_topics")
}

model PlatformUsername {
  id        String  @id @default(cuid())
  studentId String
  platform  String
  username  String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("platform_usernames")
}

model StudentGoal {
  id           String  @id @default(cuid())
  studentId    String  @unique
  weeklyTarget Int
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_goals")
}

model StudyPlan {
  id        String   @id @default(cuid())
  studentId String
  title     String
  objective String
  days      Json
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("study_plans")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum RiskTier {
  SAFE
  EARLY_WARNING
  DETENTION_RISK
  CRITICAL
}

enum AlertType {
  EARLY_WARNING
  DETENTION_RISK
  CRITICAL
}

enum AlertStatus {
  SENT
  FAILED
  SKIPPED
}
